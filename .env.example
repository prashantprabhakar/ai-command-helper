# ─── Provider ────────────────────────────────────────────────────────────────
# Which LLM provider to use.
# Options: ollama (default) | openai | anthropic | github
AI_CLI_PROVIDER=ollama

# ─── Model ───────────────────────────────────────────────────────────────────
# Override the model for the chosen provider.
# Leave blank to use each provider's built-in default.
#
#   ollama    → mistral:latest
#   openai    → gpt-4o
#   anthropic → claude-3-5-sonnet-20241022
#   github    → gpt-4o
AI_CLI_MODEL=mistral:latest

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Only the key for your chosen provider is required.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# GitHub Models (works with Copilot Pro) — github.com/settings/tokens
# No special token scopes required.
GITHUB_TOKEN=

# ─── Debug ───────────────────────────────────────────────────────────────────
# Set to 1 to print raw prompts and LLM responses to stderr.
# AI_CMD_DEBUG=1
